{
  "entities": {
    "Organization": {
      "title": "Organization Profile",
      "description": "Enterprise entity using the switchboard",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "registrationNumber": { "type": "string" },
        "industry": { "type": "string" },
        "headquarters": { "type": "string" },
        "certificateUrl": { "type": "string", "description": "URL to the uploaded registration certificate" },
        "status": { "type": "string", "enum": ["pending", "verified", "suspended"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "adminId": { "type": "string" },
        "selectedNumbers": { "type": "array", "items": { "type": "string" } },
        "isDiscoverable": { "type": "boolean", "description": "Whether this company is listed in the global directory" },
        "prefix": { "type": "string", "description": "4-digit routing prefix" },
        "trialStartDate": { "type": "string", "format": "date-time" },
        "subscriptionExpiryDate": { "type": "string", "format": "date-time", "description": "When the current paid period ends" },
        "isPaymentActive": { "type": "boolean" }
      },
      "required": ["name", "registrationNumber", "adminId"]
    },
    "Call": {
      "title": "Call Log",
      "description": "Details of a completed or ongoing call",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agentId": { "type": "string" },
        "agentName": { "type": "string" },
        "clientNumber": { "type": "string" },
        "virtualNumber": { "type": "string" },
        "type": { "type": "string", "enum": ["inbound", "outbound"] },
        "status": { "type": "string", "enum": ["completed", "missed", "ongoing", "transferred"] },
        "duration": { "type": "number", "description": "Duration in seconds" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "category": { "type": "string", "description": "AI-generated category" },
        "summary": { "type": "string", "description": "AI-generated summary" },
        "sentiment": { "type": "string", "enum": ["positive", "neutral", "negative"] },
        "cscore": { "type": "number", "description": "Customer satisfaction score 1-5" },
        "organizationId": { "type": "string" }
      },
      "required": ["agentId", "clientNumber", "type", "startTime", "organizationId"]
    },
    "Agent": {
      "title": "Agent Profile",
      "description": "System user representing a customer service agent",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["agent", "supervisor", "admin"] },
        "virtualNumber": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "busy", "offline"] },
        "organizationId": { "type": "string" },
        "metrics": {
          "type": "object",
          "properties": {
            "avgHandlingTime": { "type": "number" },
            "totalCalls": { "type": "number" },
            "avgSatisfaction": { "type": "number" }
          }
        }
      },
      "required": ["userId", "name", "email", "organizationId"]
    },
    "VirtualNumber": {
      "title": "Virtual Contact",
      "description": "Purchasable virtual number for masking",
      "type": "object",
      "properties": {
        "number": { "type": "string" },
        "country": { "type": "string", "description": "East African Country" },
        "provider": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["available", "assigned", "reserved"] },
        "organizationId": { "type": "string", "description": "Owner organization if assigned" }
      },
      "required": ["number", "country", "status"]
    },
    "UserOrgMeta": {
      "title": "User Organization Meta",
      "description": "Mapping from user ID to organization",
      "type": "object",
      "properties": {
        "orgId": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "agent"] }
      },
      "required": ["orgId", "role"]
    },
    "Lead": {
      "title": "Contact Lead",
      "description": "Anonymized contact data generated by the system for sale",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "originalNumber": { "type": "string", "description": "Masked unless purchased" },
        "region": { "type": "string" },
        "category": { "type": "string" },
        "sentiment": { "type": "string" },
        "price": { "type": "number" },
        "sellerOrgId": { "type": "string" },
        "buyerOrgId": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "sold"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["originalNumber", "region", "price", "sellerOrgId", "status"]
    },
    "SystemConfig": {
      "title": "System Configuration",
      "description": "Internal platform settings",
      "type": "object",
      "properties": {
        "mgmtUser": { "type": "string" },
        "mgmtPass": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/organizations/{orgId}": {
      "schema": "Organization",
      "description": "Enterprise organization profile"
    },
    "/organizations_meta/{userId}": {
      "schema": "UserOrgMeta",
      "description": "User to organization mapping"
    },
    "/organizations/{orgId}/calls": {
      "schema": "Call",
      "description": "Call records for an organization"
    },
    "/organizations/{orgId}/agents": {
      "schema": "Agent",
      "description": "Agents belonging to an organization"
    },
    "/virtual_numbers": {
      "schema": "VirtualNumber",
      "description": "Global pool of virtual contacts"
    },
    "/marketplace_leads": {
      "schema": "Lead",
      "description": "Global marketplace for contact leads"
    },
    "/system_config": {
      "schema": "SystemConfig",
      "description": "Platform-wide sensitive settings"
    }
  }
}
