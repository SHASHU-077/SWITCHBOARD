# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ASTERISK_SENTINEL_PASSWORD: Secure access key for the Asterisk Grid Engine
ASTERISK_SENTINEL_PASSWORD=

# GSM_SENTINEL_PASSWORD: Access key for the GSM Line Absorption Terminal
GSM_SENTINEL_PASSWORD=

# REGISTRY_PASSWORD: Access key for the Organization Routing Registry
REGISTRY_PASSWORD=

# SENTINEL_MANAGEMENT_ID: Master identifier for the platform sentinel
SENTINEL_MANAGEMENT_ID=
# SENTINEL_MANAGEMENT_KEY: Master security key for the platform sentinel
SENTINEL_MANAGEMENT_KEY=
